SEALED_RELAY_PORT=3002
SEALED_RELAY_RPC_URL=https://starknet-sepolia.public.blastapi.io/rpc/v0_8
SEALED_RELAY_ACTIONS_ADDRESS=0xYOUR_ACTIONS_CONTRACT
SEALED_RELAY_ACCOUNT_ADDRESS=0xYOUR_RELAYER_ACCOUNT
SEALED_RELAY_PRIVATE_KEY=0xYOUR_RELAYER_PRIVATE_KEY

# Optional overrides (defaults are already valid for this repo layout)
# SEALED_RELAY_GARAGA_BIN=/Users/sss/Webs/Starkwall/.venv-garaga/bin/garaga
# SEALED_RELAY_BB_BIN=/Users/sss/.bb/bb
# SEALED_RELAY_NARGO_BIN=nargo
# SEALED_RELAY_TACEO_MODE=off

# Taceo coNoir (required for real remote MPC prove)
# TACEO_BASE_URL=https://proof.taceo.network
# TACEO_ENABLE_REMOTE=true
# TACEO_API_KEY=your_api_key
# TACEO_BLUEPRINT_ID=uuid
# TACEO_VOUCHER=optional_blueprint_voucher
# TACEO_WS_URL=wss://proof.taceo.network/api/v1/reports/subs
# TACEO_FAIL_OPEN=true
# TACEO_NOIR_PUBLIC_INPUTS=0,1,2,3
# TACEO_NOIR_ABI_PATH=/app/zk/noir-sealed-bid/target/noir_sealed_bid.json
